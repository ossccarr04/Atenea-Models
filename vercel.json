{
  "version": 2,
  "builds": [
    { "src": "api/sendEmail.js", "use": "@vercel/node" },
    { "src": "dist/front/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/sendEmail", "dest": "/api/sendEmail.js" },

    { "src": "/(.*\\.(js|css|png|jpg|svg|ico|json))", "dest": "/dist/front/$1" },
    
    { "src": "/(.*)", "dest": "/dist/front/index.html" }
  ]
}